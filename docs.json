{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Flip Docs",
  "colors": {
    "primary": "#8828D9",
    "light": "#8828D9",
    "dark": "#8828D9"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index"
            ]
          },
          {
            "group": "Titles, Products and Formats",
            "pages": [
              "titles-products-formats/introduction"
            ]
          },
          {
            "group": "Organisation Settings",
            "pages": [
              "essentials/markdown",
              "essentials/code",
              "essentials/images",
              "essentials/reusable-snippets"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "API documentation",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Endpoint examples",
            "pages": [
              "api-reference/endpoint/get",
              "api-reference/endpoint/create",
              "api-reference/endpoint/delete",
              "api-reference/endpoint/webhook"
            ]
          }
        ]
      },
      {
      "tab": "Changelog",
        "groups": [
          {
            "group": "Changelog",
            "pages": [
              "changelog/introduction"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Documentation",
          "href": "https://docs.flipapp.app",
          "icon": "folder-open"
        },
        {
          "anchor": "Discord",
          "href": "https://mintlify.com/blog",
          "icon": "discord"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/FlipA1_Icon.png",
    "dark": "/logo/FlipA1_Icon.png",
    "href": "https://goflip.app"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@flipapp.app"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://flipapp.app"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "footer": {
    "socials": {
    }
  }
}
